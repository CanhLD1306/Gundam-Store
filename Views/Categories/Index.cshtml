@model IEnumerable<GundamStore.Models.Category>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Category</h1>
<div class="action-btn layout-top-spacing mb-7 d-flex align-items-center justify-content-between">
    <h5 class="mb-0 fs-5 fw-semibold"></h5>
    <a href="#" class="btn btn-primary add-category">
        <i class="fs-4 ti ti-plus"></i>
        Add
    </a>
</div>
<table class="table border text-nowrap customize-table mb-0 align-middle">
    <thead class="text-dark fs-4">
        <tr>
            <th><h6 class="fs-4 fw-semibold mb-0">Name</h6></th>
            <th><h6 class="fs-4 fw-semibold mb-0">Description</h6></th>
            <th><h6 class="fs-4 fw-semibold mb-0"></h6></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model) {
        <tr>
            <td>
                <div class="d-flex align-items-center">
                    @Html.DisplayFor(modelItem => item.Name)
                </div>
            </td>
            <td>
                <div class="d-flex align-items-center">
                    @Html.DisplayFor(modelItem => item.Description)
                </div>
            </td>
            <td>
                <div class="dropdown dropstart">
                    <a href="#" class="text-muted" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-dots-vertical fs-6"></i>
                    </a>
                    <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton">
                        <li>
                            <a href="#" class="dropdown-item d-flex align-items-center gap-3 edit-category" data-id="@item.Id">
                                <i class="fs-4 ti ti-edit"></i>
                                Edit
                            </a>
                        </li>
                        <li>
                            <a href="#" class="dropdown-item d-flex align-items-center gap-3 delete-category" data-id="@item.Id">
                                <i class="fs-4 ti ti-trash"></i>
                                Delete
                            </a>
                        </li>
                    </ul>
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>

<!-- Add Category Modal -->
<div class="modal fade" id="addCategoryModal" tabindex="-1" aria-labelledby="addCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addCategoryModalLabel">Add Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Form for editing category -->
                <form id="addCategoryForm" method="post">
                    <div class="mb-3">
                        <label for="addCategoryName" class="form-label">Name</label>
                        <input type="text" class="form-control" id="addCategoryName" name="Name" required />
                    </div>
                    <div class="mb-3">
                        <label for="addCategoryDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="addCategoryDescription" name="Description"></textarea>
                    </div>
                    <div class="modal-footer justify-content-between">
                        <button type="button" class="btn btn-secondary me-auto" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary" id="confirmAddBtn">submit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Edit Category Modal -->
<div class="modal fade" id="editCategoryModal" tabindex="-1" aria-labelledby="editCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editCategoryModalLabel">Edit Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Form for editing category -->
                <form id="editCategoryForm" method="post">
                    <input type="hidden" id="editCategoryId" name="Id" />
                    <div class="mb-3">
                        <label for="editCategoryName" class="form-label">Name</label>
                        <input type="text" class="form-control" id="editCategoryName" name="Name" required />
                    </div>
                    <div class="mb-3">
                        <label for="editCategoryDescription" class="form-label">Description</label>
                        <textarea class="form-control" id="editCategoryDescription" name="Description"></textarea>
                    </div>
                    <div class="modal-footer justify-content-between">
                        <button type="button" class="btn btn-secondary me-auto" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary" id="confirmEditBtn">submit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteCategoryModal" tabindex="-1" aria-labelledby="deleteCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p>Are you sure you want to delete this category</p>
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-secondary me-auto" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        $(document).ready(function () {
            // Add category click event
            $('.add-category').click(function(event) {
                event.preventDefault(); // Prevent default link behavior
                    // Show the modal popup
                    $('#addCategoryModal').modal('show');
                    $('#addCategoryForm')[0].reset();
            });

            // Confirm add new category
            $('#addCategoryForm').submit(function(event) {
                event.preventDefault(); // Prevent default form submission
                
                // Serialize form data
                var formData = $(this).serialize();
                
                // AJAX request to submit form data and create new category
                $.ajax({
                    url: '/Categories/Create', // Replace with your backend endpoint URL
                    type: 'POST',
                    data: formData,
                    success: function(response) {
                        // Handle success response, e.g., display success message, reload page, etc.
                        console.log('Category created successfully');
                        // Optionally, close the modal after successful submission
                        $('#addCategoryModal').modal('hide');
                        // Reload the page to reflect changes
                        location.reload();
                    },
                    error: function(xhr, status, error) {
                        // Handle error response, e.g., display error message, log error, etc.
                        console.error(error);
                        alert('An error occurred while creating the category. Please try again.');
                    }
                });
            });

            // Edit category click event
            $('.edit-category').click(function (e) {
                e.preventDefault();
                var categoryId = $(this).data('id');

                // Send AJAX request to fetch category details
                $.ajax({
                    url: '/Categories/Edit/' + categoryId,
                    type: 'GET',
                    success: function (data) {
                        // Populate edit form fields with category details
                        $('#editCategoryId').val(data.id);
                        $('#editCategoryName').val(data.name);
                        $('#editCategoryDescription').val(data.description);

                        // Show edit form popup
                        $('#editCategoryModal').modal('show');
                    },
                    error: function (xhr, status, error) {
                        // Handle error if category details cannot be fetched
                        console.error(xhr.responseText);
                    }
                });
            });

            // Confirm edit category
            $('#editCategoryForm').submit(function (e) {
                e.preventDefault();

                // Serialize form data
                var formData = $(this).serialize();

                // Send AJAX request to update category details
                $.ajax({
                    url: '/Categories/Edit/' + $('#editCategoryId').val(),
                    type: 'POST',
                    data: formData,
                    success: function (data) {
                        // Relead page when edit successfull
                        location.reload();
                        // Optionally, you can perform additional actions such as updating the category list, showing a success message, etc.
                    },
                    error: function (xhr, status, error) {
                        // Handle error if category details cannot be updated
                        console.error(xhr.responseText);
                        // Optionally, you can display an error message to the user
                    }
                });
            });

            // Delete category click event
            $('.delete-category').click(function (e) {
                e.preventDefault();
                var categoryId = $(this).data('id');
                $('#confirmDeleteBtn').attr('data-id', categoryId);
                $('#deleteCategoryModal').modal('show');
            });

            // Confirm delete button click event
            $('#confirmDeleteBtn').click(function () {
                var categoryId = $(this).attr('data-id');
                $.ajax({
                    url: '/Categories/DeleteConfirmed/' + categoryId,
                    type: 'POST',
                    success: function () {
                        // Reload page or update table as needed
                        location.reload();
                    }
                });
            });
        });
    </script>
}



