@model IEnumerable<GundamStore.Models.Banner>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Banner</h1>
<div class="action-btn layout-top-spacing mb-7 d-flex align-items-center justify-content-between">
    <h5 class="mb-0 fs-5 fw-semibold"></h5>
    <a href="#" class="btn btn-primary add-banner">
        <i class="fs-4 ti ti-plus"></i>
        Add
    </a>
</div>
<table class="table border text-nowrap customize-table mb-0 align-middle">
    <thead class="text-dark fs-4">
        <tr>
            <th><h6 class="fs-4 fw-semibold mb-0">Name</h6></th>
            <th><h6 class="fs-4 fw-semibold mb-0"></h6></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model) {
        <tr>
            <td>
                <div class="d-flex align-items-center">
                    @Html.DisplayFor(modelItem => item.Image)
                </div>
            </td>
            <td>
                <div class="dropdown dropstart">
                    <a href="#" class="text-muted" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-dots-vertical fs-6"></i>
                    </a>
                    <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton">
                        <li>
                            <a href="#" class="dropdown-item d-flex align-items-center gap-3 edit-banner" data-id="@item.Id">
                                <i class="fs-4 ti ti-edit"></i>
                                Edit
                            </a>
                        </li>
                        <li>
                            <a href="#" class="dropdown-item d-flex align-items-center gap-3 delete-banner" data-id="@item.Id">
                                <i class="fs-4 ti ti-trash"></i>
                                Delete
                            </a>
                        </li>
                    </ul>
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>

<!-- Add Banner Modal -->
<div class="modal fade" id="addBannerModal" tabindex="-1" aria-labelledby="addBannerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addBannerModalLabel">Add Banner</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Form for adding banner -->
                <form id="addBannerForm" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <input type="file" class="form-control" id="addBannerImage" name="image" accept="image/*" required />
                    </div>
                    <div class="modal-footer justify-content-between">
                        <button type="button" class="btn btn-secondary me-auto" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary" id="confirmAddBtn">submit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Edit Banner Modal -->
<div class="modal fade" id="editBannerModal" tabindex="-1" aria-labelledby="editBannerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editBannerModalLabel">Edit Banner</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Form for editing banner -->
                <form id="editBannerForm" method="post">
                    <input type="hidden" id="editBannerId" name="Id" />
                    <div class="mb-3">
                        <label for="editBannerImage" class="form-label">Name</label>
                        <input type="text" class="form-control" id="editBannerImage" name="Image" required />
                    </div>
                    <div class="modal-footer justify-content-between">
                        <button type="button" class="btn btn-secondary me-auto" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary" id="confirmEditBtn">submit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteBannerModal" tabindex="-1" aria-labelledby="deleteBannerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p>Are you sure you want to delete this banner</p>
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-secondary me-auto" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        $(document).ready(function () {
            // Add banner click event
            $('.add-banner').click(function(event) {
                event.preventDefault(); // Prevent default link behavior
                    // Show the modal popup
                    $('#addBannerModal').modal('show');
                    $('#addBannerForm')[0].reset();
            });

            // Confirm add new banner
            $('#addBannerForm').submit(function(event) {
                event.preventDefault(); // Prevent default form submission
                
                // Serialize form data
                var formData = new FormData($(this)[0]);
                
                // AJAX request to submit form data and create new banner
                $.ajax({
                    url: '/Banners/Create', // Replace with your backend endpoint URL
                    type: 'POST',
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function(response) {
                        // Handle success response, e.g., display success message, reload page, etc.
                        console.log('Banner created successfully');
                        // Optionally, close the modal after successful submission
                        $('#addBannerModal').modal('hide');
                        // Reload the page to reflect changes
                        location.reload();
                    },
                    error: function(xhr, status, error) {
                        // Handle error response, e.g., display error message, log error, etc.
                        console.error(error);
                        alert('An error occurred while creating the banner. Please try again.');
                    }
                });
            });

            // Edit banner click event
            $('.edit-banner').click(function (e) {
                e.preventDefault();
                var bannerId = $(this).data('id');

                // Send AJAX request to fetch banner details
                $.ajax({
                    url: '/Banners/Edit/' + bannerId,
                    type: 'GET',
                    success: function (data) {
                        // Populate edit form fields with banner details
                        $('#editBannerId').val(data.id);
                        $('#editBannerImage').val(data.image);

                        // Show edit form popup
                        $('#editBannerModal').modal('show');
                    },
                    error: function (xhr, status, error) {
                        // Handle error if banner details cannot be fetched
                        console.error(xhr.responseText);
                    }
                });
            });

            // Confirm edit banner
            $('#editBannerForm').submit(function (e) {
                e.preventDefault();

                // Serialize form data
                var formData = $(this).serialize();

                // Send AJAX request to update banner details
                $.ajax({
                    url: '/Banners/Edit/' + $('#editBannerId').val(),
                    type: 'POST',
                    data: formData,
                    success: function (data) {
                        // Relead page when edit successfull
                        location.reload();
                        // Optionally, you can perform additional actions such as updating the banner list, showing a success message, etc.
                    },
                    error: function (xhr, status, error) {
                        // Handle error if banner details cannot be updated
                        console.error(xhr.responseText);
                        // Optionally, you can display an error message to the user
                    }
                });
            });

            // Delete banner click event
            $('.delete-banner').click(function (e) {
                e.preventDefault();
                var bannerId = $(this).data('id');
                $('#confirmDeleteBtn').attr('data-id', bannerId);
                $('#deleteBannerModal').modal('show');
            });

            // Confirm delete button click event
            $('#confirmDeleteBtn').click(function () {
                var bannerId = $(this).attr('data-id');
                $.ajax({
                    url: '/Banners/DeleteConfirmed/' + bannerId,
                    type: 'POST',
                    success: function () {
                        // Reload page or update table as needed
                        location.reload();
                    }
                });
            });
        });
    </script>
}



