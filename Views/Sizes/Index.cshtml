@model IEnumerable<GundamStore.Models.Size>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Size</h1>

<div class="action-btn layout-top-spacing mb-7 d-flex align-items-center justify-content-between">
    <h5 class="mb-0 fs-5 fw-semibold"></h5>
    <a href="#" class="btn btn-primary add-size">
        <i class="fs-4 ti ti-plus"></i>
        Add
    </a>
</div>
<table class="table border text-nowrap customize-table mb-0 align-middle">
    <thead class="text-dark fs-4">
        <tr>
            <th><h6 class="fs-4 fw-semibold mb-0">Name</h6></th>
            <th><h6 class="fs-4 fw-semibold mb-0"></h6></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model) {
        <tr>
            <td>
                <div class="d-flex align-items-center">
                    @Html.DisplayFor(modelItem => item.Name)
                </div>
            </td>
            <td>
                <div class="dropdown dropstart">
                    <a href="#" class="text-muted" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-dots-vertical fs-6"></i>
                    </a>
                    <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton">
                        <li>
                            <a href="#" class="dropdown-item d-flex align-items-center gap-3 edit-size" data-id="@item.Id">
                                <i class="fs-4 ti ti-edit"></i>
                                Edit
                            </a>
                        </li>
                        <li>
                            <a href="#" class="dropdown-item d-flex align-items-center gap-3 delete-size" data-id="@item.Id">
                                <i class="fs-4 ti ti-trash"></i>
                                Delete
                            </a>
                        </li>
                    </ul>
                </div>
            </td>
        </tr>
    }
    </tbody>
</table>

<!-- Add Size Modal -->
<div class="modal fade" id="addSizeModal" tabindex="-1" aria-labelledby="addSizeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addSizeModalLabel">Add Size</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Form for editing size -->
                <form id="addSizeForm" method="post">
                    <div class="mb-3">
                        <label for="addSizeName" class="form-label">Name</label>
                        <input type="text" class="form-control" id="addSizeName" name="Name" required />
                    </div>
                    <div class="modal-footer justify-content-between">
                        <button type="button" class="btn btn-secondary me-auto" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary" id="confirmAddBtn">submit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Edit Size Modal -->
<div class="modal fade" id="editSizeModal" tabindex="-1" aria-labelledby="editSizeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editSizeModalLabel">Edit Size</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- Form for editing size -->
                <form id="editSizeForm" method="post">
                    <input type="hidden" id="editSizeId" name="Id" />
                    <div class="mb-3">
                        <label for="editSizeName" class="form-label">Name</label>
                        <input type="text" class="form-control" id="editSizeName" name="Name" required />
                    </div>
                    <div class="modal-footer justify-content-between">
                        <button type="button" class="btn btn-secondary me-auto" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary" id="confirmEditBtn">submit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteSizeModal" tabindex="-1" aria-labelledby="deleteSizeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <p>Are you sure you want to delete this size</p>
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-secondary me-auto" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        $(document).ready(function () {
            // Add size click event
            $('.add-size').click(function(event) {
                event.preventDefault(); // Prevent default link behavior
                    // Show the modal popup
                    $('#addSizeModal').modal('show');
                    $('#addSizeForm')[0].reset();
            });

            // Confirm add new size
            $('#addSizeForm').submit(function(event) {
                event.preventDefault(); // Prevent default form submission
                
                // Serialize form data
                var formData = $(this).serialize();
                
                // AJAX request to submit form data and create new size
                $.ajax({
                    url: '/Sizes/Create', // Replace with your backend endpoint URL
                    type: 'POST',
                    data: formData,
                    success: function(response) {
                        // Handle success response, e.g., display success message, reload page, etc.
                        console.log('Size created successfully');
                        // Optionally, close the modal after successful submission
                        $('#addSizeModal').modal('hide');
                        // Reload the page to reflect changes
                        location.reload();
                    },
                    error: function(xhr, status, error) {
                        // Handle error response, e.g., display error message, log error, etc.
                        console.error(error);
                        alert('An error occurred while creating the size. Please try again.');
                    }
                });
            });

            // Edit size click event
            $('.edit-size').click(function (e) {
                e.preventDefault();
                var sizeId = $(this).data('id');

                // Send AJAX request to fetch size details
                $.ajax({
                    url: '/Sizes/Edit/' + sizeId,
                    type: 'GET',
                    success: function (data) {
                        // Populate edit form fields with size details
                        $('#editSizeId').val(data.id);
                        $('#editSizeName').val(data.name);

                        // Show edit form popup
                        $('#editSizeModal').modal('show');
                    },
                    error: function (xhr, status, error) {
                        // Handle error if size details cannot be fetched
                        console.error(xhr.responseText);
                    }
                });
            });

            // Confirm edit size
            $('#editSizeForm').submit(function (e) {
                e.preventDefault();

                // Serialize form data
                var formData = $(this).serialize();

                // Send AJAX request to update size details
                $.ajax({
                    url: '/Sizes/Edit/' + $('#editSizeId').val(),
                    type: 'POST',
                    data: formData,
                    success: function (data) {
                        // Relead page when edit successfull
                        location.reload();
                        // Optionally, you can perform additional actions such as updating the size list, showing a success message, etc.
                    },
                    error: function (xhr, status, error) {
                        // Handle error if size details cannot be updated
                        console.error(xhr.responseText);
                        // Optionally, you can display an error message to the user
                    }
                });
            });

            // Delete size click event
            $('.delete-size').click(function (e) {
                e.preventDefault();
                var sizeId = $(this).data('id');
                $('#confirmDeleteBtn').attr('data-id', sizeId);
                $('#deleteSizeModal').modal('show');
            });

            // Confirm delete button click event
            $('#confirmDeleteBtn').click(function () {
                var sizeId = $(this).attr('data-id');
                $.ajax({
                    url: '/Sizes/DeleteConfirmed/' + sizeId,
                    type: 'POST',
                    success: function () {
                        // Reload page or update table as needed
                        location.reload();
                    }
                });
            });
        });
    </script>
}
